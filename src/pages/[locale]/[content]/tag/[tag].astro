---
import ContentTagView from '@/components/contents/views/ContentTagView.astro';
import {
  CONTENT_TAG_CLOUD_LIMIT,
  collectTags,
  collectTopTags,
  getPublishedContents,
  getSecondaryLocales,
  tagToSlug,
  getContentDirectoryNames,
} from '@/lib/contents';

// Locale-prefixed tag archives (`/<locale>/contents/tag/<tag>`). One page per
// (non-default locale × tag that exists in that locale). Emits nothing when
// i18n is off.
export async function getStaticPaths() {
  const paths: {
    params: { locale: string; tag: string, content: string };
    props: {
      tag: string;
      contents: Awaited<ReturnType<typeof getPublishedContents>>;
      visibleTags: string[];
      locale: string;
      contentDirectoryName: string;
    };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    for (const contentDirectoryName of getContentDirectoryNames()) {
      const contents = await getPublishedContents(contentDirectoryName, locale);
      const tags = collectTags(contents);
      const topTags = collectTopTags(contents, CONTENT_TAG_CLOUD_LIMIT);

      for (const tag of tags) {
        const contentsForTag = contents.filter((p) => p.data.tags.includes(tag));
        const visibleTags = topTags.includes(tag)
          ? topTags
          : [tag, ...topTags.slice(0, CONTENT_TAG_CLOUD_LIMIT - 1)];
        paths.push({
          params: { locale, tag: tagToSlug(tag), content: contentDirectoryName },
          props: { tag, contents: contentsForTag, visibleTags, locale, contentDirectoryName },
        });
      }
    }
  }

  return paths;
}

const { tag, contents, visibleTags, locale, contentDirectoryName } = Astro.props;
---

<ContentTagView locale={locale} tag={tag} contents={contents} visibleTags={visibleTags} contentDirectoryName={contentDirectoryName} />
