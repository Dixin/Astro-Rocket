---
import ContentIndexView from '@/components/contents/views/ContentIndexView.astro';
import { getSecondaryLocales } from '@/lib/contents';
import { getContentDirectoryNames } from '@/lib/contents';

// Locale-prefixed blog landing pages (`/<locale>/blog`). One page per
// non-default locale. Emits nothing when i18n is off or only one locale is
// configured, so single-locale builds are unchanged. A locale with no posts
// yet still gets a page (the view shows the empty state) so the
// LanguageSwitcher never lands on a 404.
export function getStaticPaths() {
  const paths: {
    params: { locale: string; content: string };
    props: { locale: string; contentDirectoryName: string };
  }[] = [];

  for (const locale of getSecondaryLocales()) {
    for (const contentDirectoryName of getContentDirectoryNames()) {
      paths.push({
        params: { locale, content: contentDirectoryName },
        props: { locale, contentDirectoryName }
      });
    }
  }
  return paths;
}

const { locale, contentDirectoryName } = Astro.props;
---

<ContentIndexView locale={locale} contentDirectoryName={contentDirectoryName} />
