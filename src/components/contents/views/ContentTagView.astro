---
/**
 * ContentTagView — a tag archive page.
 *
 * Shared body for the default-locale route (`/content/tag/<tag>`) and the
 * locale-prefixed route (`/<locale>/content/tag/<tag>`). The matching contents and
 * the visible tag cloud are resolved in each route's `getStaticPaths` and
 * passed in; URLs are built locale-aware via `lib/contents`.
 */
import type { CollectionEntry } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import ContentCard from '@/components/contents/ContentCard.astro';
import TagList from '@/components/contents/TagList.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { t, defaultLocale } from '@/i18n';
import { getContentBaseUrl, getContentUrl } from '@/lib/contents';

interface Props {
  /** Locale whose contents this archive renders. Defaults to the site default. */
  locale?: string;
  /** The active tag (display form). */
  tag: string;
  /** Contents carrying this tag, in the locale. */
  contents: CollectionEntry<'contents'>[];
  /** Tags to render in the cloud (always includes the active tag). */
  visibleTags: string[];
  contentDirectoryName: string;
  contentUrlPath?: string;
  i18nKey?: string;
}

const { locale = defaultLocale, tag, contents, visibleTags, contentDirectoryName, contentUrlPath = contentDirectoryName, i18nKey = contentDirectoryName } = Astro.props;

const contentHref = getContentBaseUrl(contentUrlPath, locale);
const countKey = contents.length === 1 ? `${i18nKey}.tagCountOne` : `${i18nKey}.tagCountOther`;
---

<PageLayout
  title={t(`${i18nKey}.tagMetaTitle`, locale, { tag })}
  description={t(`${i18nKey}.tagMetaDescription`, locale, { tag })}
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="default" pill>
      <Icon name="tag" size="sm" />
      {t(`${i18nKey}.tagBadge`, locale)}
    </Badge>

    <h1
      slot="title"
      class="!text-4xl sm:!text-5xl md:!text-6xl lg:!text-7xl break-words [overflow-wrap:anywhere]"
    >#{tag}</h1>

    <p slot="description">
      {t(countKey, locale, { count: contents.length, tag })}
    </p>

    <Button href={contentHref}>
      <Icon name="arrow-left" size="sm" />
      {t(`${i18nKey}.allContents`, locale)}
    </Button>
  </Hero>

  <section class="bg-background-secondary py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4" data-reveal>
        {visibleTags.length > 0 && (
          <TagList tags={visibleTags} active={tag} locale={locale} class="justify-center" contentDirectoryName={contentDirectoryName} contentUrlPath={contentUrlPath} />
        )}
      </div>

      {contents.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {contents.map((content, index) => (
            <ContentCard
              title={content.data.title}
              description={content.data.description}
              href={getContentUrl(contentDirectoryName, content.id, locale, contentUrlPath)}
              publishedAt={content.data.publishedAt}
              tags={content.data.tags}
              author={content.data.author}
              image={content.data.image}
              svgSlug={content.data.svgSlug}
              body={content.body}
              revealDelay={index % 3}
              eager={index === 0}
              placeholder={content.data.placeholder}
              year={content.data.year}
              icon={content.data.icon}
              contentDirectoryName={contentDirectoryName}
            />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <div class="bg-background mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
            <Icon name="file-text" size="lg" class="text-foreground-muted" />
          </div>
          <p class="text-foreground-muted text-lg">{t(`${i18nKey}.tagEmpty`, locale)}</p>
          <div class="mt-6">
            <Button href={contentHref} size="sm">
              <Icon name="arrow-left" size="sm" />
              {t(`${i18nKey}.tagBackToAll`, locale)}
            </Button>
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
