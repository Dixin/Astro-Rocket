---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate, getReadingTime } from '@/lib/utils';
import { t, getLocaleFromPath } from '@/i18n';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import ContentImageSVG from '@/components/contents/ContentImageSVG.astro';
import { cn } from '@/lib/cn';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  tags?: string[];
  featured?: boolean;
  author?: string;
  image?: ImageMetadata;
  svgSlug?: string;
  /**
   * Marks the first card on a listing page. On mobile it reveals on load with
   * the standard animation instead of waiting for scroll, matching how the
   * first card on pages without a heading above the grid (e.g. projects)
   * already animates in.
   */
  eager?: boolean;
  /**
   * Stagger index for the scroll-reveal cascade. Maps to `data-reveal-delay`
   * (1–4 → 100–400ms) so a grid of cards rises one after another instead of
   * all at once. Pass the map index; 0 (or omitted) means no delay.
   */
  revealDelay?: number;
  class?: string;
  /** Raw ciontent body, used to estimate reading time (CJK-aware). */
  body?: string;
  placeholder?: boolean;
  year?: number;
  icon?: string;
  contentDirectoryName: string;
  i18nKey?: string;
}

const {
  title,
  description,
  href,
  publishedAt,
  tags = [],
  author,
  image,
  svgSlug,
  eager = false,
  revealDelay,
  class: className,
  body,
  placeholder = false,
  year,
  icon,
  contentDirectoryName,
  i18nKey = contentDirectoryName,
} = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);

// Reading time from the actual content body (falls back to the description if no
// body is passed). Counts CJK characters, so space-less languages such as
// Chinese, Japanese, and Korean aren't all estimated as "1 min".
const readingTime = getReadingTime(body ?? description);

const isClickable = !!href && !placeholder;
const Element = isClickable ? 'a' : 'div';
---

<article 
  class:list={cn(
    "group rounded-lg border bg-background p-6 shadow-lg ring-1 ring-brand-500/20 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-xl",
    isClickable ? 'border-brand-500 hover:border-brand-300' : 'border-foreground-muted hover:border-foreground',
    className
  )} 
  data-reveal data-reveal-delay={revealDelay || undefined} data-reveal-eager={eager ? '' : undefined}>

  <Element href={href} class="block">
    {icon ? (
      <div class="mb-3 flex items-start justify-between gap-4">
        <div class={cn('w-10 h-10 rounded-xl flex items-center justify-center  shrink-0', isClickable ? 'bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500 group-hover:text-brand-300' : 'bg-gradient-to-br from-foreground/20 to-foreground/5 text-foreground')}>
          <Icon name={icon} size="sm" />
        </div>
        <Icon name="arrow-up-right" size="sm" class={cn('transition-colors shrink-0 ml-auto', isClickable ? 'text-brand-500 group-hover:text-brand-300' : 'text-foreground-muted')} />
      </div>
    ) : (
      <div
        class="relative mb-4 overflow-hidden rounded-md shadow-md transition-shadow duration-300 group-hover:shadow-lg
          bg-background-secondary bg-gradient-to-br from-brand-100/65 to-transparent dark:from-brand-900/60 dark:to-brand-600/25"
        style="color: var(--brand-500);"
      >
        {svgSlug ? (
          <div class="transition-transform duration-300 group-hover:scale-105">
            <ContentImageSVG slug={svgSlug} title={title} contentDirectoryName={contentDirectoryName} />
          </div>
        ) : image ? (
          <Image
            src={image}
            alt={title}
            widths={[320, 640, 960]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
            class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div />
        )}
      </div>
    )}
    

    <h2 class={cn('font-display text-xl font-bold transition-colors mb-2', isClickable ? 'text-brand-500 group-hover:text-brand-300' : 'text-foreground')}>
      {title}
    </h2>

    <p class="text-foreground-muted line-clamp-2 mb-4">
      {description}
    </p>

    <div class="flex flex-wrap items-center gap-3 text-sm text-foreground-subtle">
      {author && (
        <div class="flex items-center gap-2">
          <Logo size="sm" letter={author.charAt(0).toUpperCase()} />
          <span class="font-medium">{author}</span>
        </div>
      )}

      <time datetime={publishedAt.toISOString()} class="flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
        {year ? year.toString(10) : formatDate(publishedAt, locale)}
      </time>

      {isClickable && (
        <span class="flex items-center gap-1">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t(`${i18nKey}.readingTime`, locale, { minutes: readingTime })}
        </span>
      )}
    </div>

    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border transition-colors">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </Element>
</article>
